# Simple cube OBJ
# 8 vertices, 12 triangles (6 faces, 2 triangles each)

v  1.0  1.0 -1.0
v  1.0 -1.0 -1.0
v  1.0  1.0  1.0
v  1.0 -1.0  1.0
v -1.0  1.0 -1.0
v -1.0 -1.0 -1.0
v -1.0  1.0  1.0
v -1.0 -1.0  1.0

# Front face (z=1)
f 3 7 8
f 3 8 4

# Back face (z=-1)
f 1 5 6
f 1 6 2

# Top face (y=1)
f 5 7 3
f 5 3 1

# Bottom face (y=-1)
f 2 6 8
f 2 8 4

# Right face (x=1)
f 1 3 4
f 1 4 2

# Left face (x=-1)
f 5 7 6
f 7 8 6
